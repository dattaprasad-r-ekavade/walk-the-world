# --- Optional tokens (the app runs without them on a basic globe) ---

# Cesium ion token — enables high-res world imagery, terrain, and (by default)
# Google Photorealistic 3D Tiles. Free at https://ion.cesium.com/tokens
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# If your host caps secret length (e.g. 255 chars), split the token across two
# vars instead — the app concatenates _1 + _2. Leave the single var empty.
# NEXT_PUBLIC_CESIUM_ION_TOKEN_1=
# NEXT_PUBLIC_CESIUM_ION_TOKEN_2=

# Google Maps Platform API key with "Map Tiles API" enabled — streams Google
# Photorealistic 3D Tiles directly. https://developers.google.com/maps/documentation/tile/3d-tiles

# Cesium Workers/Assets load from unpkg by default (smaller deploys). Set to
# /cesium to bundle local copies into public/cesium instead (offline Docker).
# NEXT_PUBLIC_CESIUM_BASE_URL=/cesium
