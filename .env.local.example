# Cloudflare R2 cache and Overture manifest. These can be operated within the
# Cloudflare free tier. Keep all secret values server-side in Vercel.
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Protect editor writes and asset uploads.
EDITOR_SECRET=

# Optional public R2 custom domain for direct cache reads.
NEXT_PUBLIC_R2_PUBLIC_BASE=

# Vercel supplies its deployment URL automatically; set this only when attaching
# a custom domain.
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
